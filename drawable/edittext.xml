<?xml version="1.0" encoding="utf-8"?>
<!-- Create a drawable resource file -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Specify the box background color -->
    <solid android:color="#EFEFEF" /> <!-- Change the color as desired -->
    <!-- Specify the border -->
    <stroke
        android:width="1dp"
        android:color="@color/red"/> <!-- Border width -->
      <!-- Border color -->

    <!-- Add some padding inside the box -->
    <padding
        android:left="8dp"
        android:right="8dp"
        android:top="8dp"
        android:bottom="8dp" />

    <corners android:radius="12dp" />
</shape>
